# ===========================
# Inari — Global Gitignore
# ===========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/

# Environment & secrets
.env
.env.*
!.env.example

# Database & persistent data
bot/data/*.db
bot/data/*.db-shm
bot/data/*.db-wal

dashboard/src/assets/hero.png
dashboard/src/assets/react.svg
dashboard/src/assets/vite.svg

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Local config
*.local